/**
 * DB_媒体分類シートを作成して分類ルールを書き込む（1回だけ実行）
 * =============================================================
 * 使い方:
 *  1. スプレッドシート → 拡張機能 → Apps Script
 *  2. 「＋」→「スクリプト」で新規ファイルを作り、この内容を貼り付け → 保存
 *  3. 関数リストで setupMediaClass を選び「実行」（初回は承認）
 *  4. スプレッドシートに DB_媒体分類 タブができて分類が入っていればOK
 *     （以後はダッシュボードの媒体別売上パネルのプルダウンで「入店用途／営業区分別」に切替可能）
 *
 *  ※ここに載っていない媒体は自動で「予約」（営業区分は媒体名に「ランチ」があればランチ、他はディナー）。
 *    分類を変えたい／媒体を追加したい時は、DB_媒体分類 タブに行を足す・直すだけ。
 */
function setupMediaClass() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sh = ss.getSheetByName('DB_媒体分類');
  if (!sh) sh = ss.insertSheet('DB_媒体分類');
  sh.clear();

  sh.getRange(1, 1, 1, 4).setValues([['媒体', '入店用途', '営業区分', 'メモ']])
    .setFontWeight('bold').setBackground('#efe9dd');

  // 入店用途の対応（営業区分は空欄＝自動判定：媒体名にランチ→ランチ、他はディナー）
  var rows = [
    ['Live GATE',   '外販',       '', ''],
    ['Peevo',       '外販',       '', ''],
    ['Ring-style',  '外販',       '', ''],
    ['いちご屋',     '外販',       '', ''],
    ['フリー',       'フリー',     '', ''],
    ['リピーター',   'リピーター',  '', ''],
    ['鍋倉',         'リピーター',  '', ''],
    ['キュア鍋',     'リピーター',  '', ''],
    ['本店パス',     '他店パス',    '', '']
  ];
  sh.getRange(2, 1, rows.length, 4).setValues(rows);

  sh.getRange('A1').setNote(
    '入店用途: ここに載っていない媒体はすべて「予約」扱い。\n' +
    '営業区分: 空欄なら自動判定（媒体名に「ランチ」→ランチ、それ以外→ディナー）。\n' +
    '　特定の媒体をランチ/ディナーに固定したい時だけC列に入力。\n' +
    '媒体名は「分析_媒体別日次」の媒体列と同じ表記にしてください。\n' +
    '種類を増やす（例: 新しい入店用途）のも、行を足すだけでOK。'
  );
  sh.setFrozenRows(1);
  sh.setColumnWidths(1, 4, 150);
  SpreadsheetApp.flush();
}
